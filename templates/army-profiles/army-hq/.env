# Hermes Army profile environment
# Copy this file to ~/.hermes/profiles/<profile>/.env and fill in the placeholders.

# LLM provider
KIMI_API_KEY=__KIMI_API_KEY__

# Telegram bot for THIS profile (one token per live consumer — do not share)
TELEGRAM_BOT_TOKEN=__TELEGRAM_BOT_TOKEN__
TELEGRAM_ALLOWED_USERS=__YOUR_TELEGRAM_USER_ID__

# Shared army kanban board
HERMES_KANBAN_BOARD=army

# Obsidian vault path
OBSIDIAN_VAULT_PATH="/Users/$USER/Documents/Hermes Vault"

# Optional: override terminal timeout
TERMINAL_TIMEOUT=60
